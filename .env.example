# ── Copy to .env and edit before running locally ─────────────────
# Required
DATABASE_URL=postgres://lottery:lottery_secret@localhost:5432/lottery_db?sslmode=disable
REDIS_URL=redis://localhost:6379/0
# Must be at least 32 characters. Generate with: openssl rand -base64 48
JWT_SECRET=please-replace-with-a-real-secret-of-at-least-32-chars

# Optional (defaults shown)
PORT=8080
ENV=development
LOG_LEVEL=info
PRETTY=true

READ_TIMEOUT=10s
WRITE_TIMEOUT=30s
IDLE_TIMEOUT=120s
SHUTDOWN_TIMEOUT=30s
MAX_REQUEST_BYTES=1048576

JWT_EXPIRY=24h
LOCK_TTL=5s
MAX_WINNERS=100

# Auth-specific rate limits (defends /auth/login from brute force)
AUTH_RATE_LIMIT_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW=1m

# General API rate limits
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_WINDOW=1m

# Comma-separated, or "*" for all. Leave empty to disable CORS.
CORS_ALLOWED_ORIGINS=

MIGRATE_ON_START=true

# Idempotent admin bootstrap (omit in production once an admin exists)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=System Admin
